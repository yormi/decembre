{
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[Recent project activity]'; tail -25 'working files/changelog.md' 2>/dev/null || echo '(no changelog yet)'"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[Team-leader inbox]'; entries=$(awk '/^## Entries/{flag=1; next} flag' team-coordination/team-leader/inbox.md 2>/dev/null | sed '/^[[:space:]]*$/d'); if [ -n \"$entries\" ]; then echo \"$entries\"; else echo '(empty)'; fi"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/guillaume/.claude/skills/shadow-watch/hook.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/guillaume/Documents/Random_Projects/decembre/scripts/challenger-critique-hook.sh"
          }
        ]
      }
    ]
  }
}
